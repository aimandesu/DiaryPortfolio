@using DiaryPortfolio.Application.DTOs
@model ResumeReportDto

@{
    ViewData["Title"] = "Resume Report";
    Layout = null; // Add this!
}

<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="/css/output.css" />
    <style>
     
    .resume-container {
        max-width: 900px;
        margin: 20px auto;
        background: #fff;
        padding: 40px;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #333;
    }

    @@media print {
        .resume-container { box-shadow: none; margin: 0; padding: 0; }
        body { background: white; }
    }
    </style>
    
</head>
<body>
    <div class="resume-container">
    @if (Model?.User != null)
    {
        <header class="flex flex-row justify-between">
            <div class="flex flex-col">
                <div class="flex flex-row gap-2 items-center">
                    <h1 class="text-3xl font-bold">@Model.User.Name</h1>
                    <p>@Model.User.Title</p>
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <span class="flex items-center gap-2">
                        <i data-lucide="mail"></i>
                        <p>@Model.User.Email</p>
                    </span>
                    <span class="flex items-center gap-2">
                        <i data-lucide="user"></i>   
                        <p>@Model.User.Age years old</p>
                    </span>
                    <span class="flex items-center gap-2">
                        <i data-lucide="map-pin"></i>   
                        <p>@Model.User.Address</p>
                    </span>
                </div>
                <span class="flex items-center gap-2">
                    <i data-lucide="link" class="w-4 h-4"></i>   
                    <a href="https://aimanafiq.com/portfolio-management/profile/@Model.User.UserName" 
                        class="hover:underline">
                        https://aimanafiq.com/portfolio-management/profile/@Model.User.UserName
                    </a>
                </span>
            </div>
            <div>
                @if (!string.IsNullOrEmpty(Model?.User?.ProfilePhoto?.Url))
                {
                    <img src="@Model.User.ProfilePhoto.Url" 
                        alt="Profile Picture" 
                        class="object-cover w-32 h-32 mx-auto mb-4 border-2 border-gray-300 rounded-full" />
                }
            </div>
        </header>

        <div class="">
            <aside class="">
                <section>
                    <h3 class="" >Profile</h3>
                    <hr class="border-t-4 border-black" />
                    <p class="mt-2">@Model.User.About</p>
                </section>
                
                <section>
                    <h3 class="text-red-300">Details</h3>
                    <p><strong>Age:</strong> @Model.User.Age</p>
                </section>
            </aside>

            <main class="">
                <section>
                    <h3 class="section-title">Professional Experience</h3>
                    <hr class="border-t-4 border-black" />
                    
                    @if (Model.Experiencs != null && Model.Experiencs.Any())
                    {
                        @foreach (var exp in Model.Experiencs)
                        {
                            <div class="flex flex-col">
                                <div class="flex flex-row justify-between">
                                    <div class="flex flex-col">
                                        <span class="font-bold">@exp.Company</span>
                                        <span class="">@exp.Role</span>
                                    </div>
                                    <div class="flex flex-col items-end">
                                        <span class="text-sm">
                                            @exp.StartDate?.ToString("MMM yyyy") - 
                                            @(exp.EndDate.HasValue ? exp.EndDate.Value.ToString("MMM yyyy") : "Present")
                                        </span>
                                       @if (exp.Location != null)
                                        {
                                            <p class="text-sm">@exp.Location.Name</p>
                                        }
                                    </div>
                                </div>
                                <p class="">@exp.Description</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p>No work experience listed.</p>
                    }
                </section>
            </main>
        </div>
    }
    else
    {
        <div class="alert alert-warning">Resume data is unavailable.</div>
    }
</div>
<script src="https://unpkg.com/lucide@1.8.0"></script>
<script>
    lucide.createIcons({
        attrs: {
        width: 16,
        height: 16,
        'stroke-width': 2
    }
    });
</script>
</body>
</html>

