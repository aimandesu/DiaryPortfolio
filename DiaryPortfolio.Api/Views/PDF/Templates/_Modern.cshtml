@using DiaryPortfolio.Application.DTOs.Reporting
@model ResumeReportDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
    <link rel="stylesheet" href="/css/output.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<style>
    /* Critical document-level structure rules best kept out of basic tailwind flow */
    .resume-container {
        width: 210mm;
        min-height: 297mm;
    }
    
    @@media print {
        body {
            background-color: white !important;
        }
        .resume-container {
            margin: 0 !important;
            box-shadow: none !important;
        }
    }
</style>

<body class="box-border m-0 bg-red-600 font-['Inter',sans-serif]">

<!-- Grid wrapper converting: display:grid; grid-template-columns: 280px 1fr; -->
<div class="resume-container mx-auto my-5 bg-white grid grid-cols-[280px_1fr] shadow-[0_12px_40px_rgba(0,0,0,0.12)]">
    
@if (Model?.User != null)
{
    <!-- Sidebar Element -->
    <aside class="bg-[#173042] text-white p-9">

        @if (!string.IsNullOrEmpty(Model.User.ProfilePhoto?.Url))
        {
            <img class="w-[130px] h-[130px] rounded-full block mx-auto object-cover border-[5px] border-white/20"
                 src="@Model.User.ProfilePhoto.Url"/>
        }

        <h1 class="text-center mt-5 text-[30px] font-bold">@Model.User.Name</h1>

        <p class="text-center opacity-85 mb-10">
            @Model.User.Title
        </p>

        <!-- Contact Section -->
        <section class="mb-9">
            <h2 class="text-[13px] tracking-[3px] mb-2 font-bold">CONTACT</h2>
            <div class="h-[3px] bg-[#1b3346] mb-4.5"></div>
            <p class="leading-[1.7] text-[14px]">@Model.User.Email</p>
            <p class="leading-[1.7] text-[14px]">@Model.User.Address</p>
            <p class="leading-[1.7] text-[14px]">@Model.User.Age years old</p>
        </section>

        <!-- Profile Section -->
        @if (!string.IsNullOrWhiteSpace(Model.User.About))
        {
            <section class="mb-9">
                <h2 class="text-[13px] tracking-[3px] mb-2 font-bold">PROFILE</h2>
                <div class="h-[3px] bg-[#1b3346] mb-4.5"></div>
                <p class="leading-[1.7] text-[14px]">
                    @Model.User.About
                </p>
            </section>
        }

    </aside>

    <!-- Main Content Panel -->
    <main class="p-[42px]">

        @if (Model.Experiencs.Any())
        {
            <section class="mb-[42px]">
                <h2 class="text-[16px] tracking-[2px] mb-2 font-bold text-[#173042]">WORK EXPERIENCE</h2>
                <div class="h-[3px] bg-[#1b3346] mb-4.5"></div>

                @foreach (var exp in Model.Experiencs)
                {
                    <div class="mb-[30px]">
                        <div class="flex justify-between items-start">
                            <div>
                                <div class="text-[18px] font-bold text-gray-900">
                                    @exp.Company
                                </div>
                                <div class="text-[#666] mt-1">
                                    @exp.Role
                                </div>
                            </div>
                            <div class="text-[13px] text-[#777]">
                                @exp.StartDate?.ToString("MMM yyyy") - @(exp.EndDate?.ToString("MMM yyyy") ?? "Present")
                            </div>
                        </div>

                        @if (exp.Location != null)
                        {
                            <div class="text-[#999] text-[13px] mt-1.5 mb-3">
                                @exp.Location.AddressLine1
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(exp.Description))
                        {
                            <ul class="m-0 pl-5 list-disc">
                                @foreach (var line in exp.Description.Split('\n'))
                                {
                                    if (!string.IsNullOrWhiteSpace(line))
                                    {
                                        <li class="leading-[1.7] mb-1.5 text-gray-700">@line.Trim()</li>
                                    }
                                }
                            </ul>
                        }
                    </div>
                }
            </section>
        }

    </main>
}

</div>

<script src="https://unpkg.com/lucide@latest"></script>
<script>
    lucide.createIcons();
</script>
</body>
</html>